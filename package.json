{
  "name": "llm-job-tracker",
  "version": "0.1.0",
  "description": "Scaffold a local job-search workspace for LLM agents.",
  "type": "module",
  "bin": {
    "llm-job-tracker": "bin/job-tracker.js",
    "job-tracker": "bin/job-tracker.js"
  },
  "files": [
    "bin/",
    "config/",
    "candidate/",
    "strategy/",
    "style/",
    "templates/",
    "data/",
    "skills/",
    "scripts/check-deps.sh",
    "scripts/check-workspace.py",
    "scripts/export-starter.sh",
    "scripts/generate_pdf.py",
    "scripts/install.sh",
    "scripts/llm-hooks/",
    "scripts/resume.css",
    "START_HERE.md",
    ".gitignore",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "check": "node --check bin/job-tracker.js && bash -n scripts/install.sh && bash -n scripts/check-deps.sh && scripts/check-public.sh && npm_config_cache=/tmp/job-tracker-npm-cache npm pack --dry-run"
  },
  "keywords": [
    "job-search",
    "resume",
    "llm",
    "claude",
    "codex",
    "tracker",
    "agent",
    "ai",
    "career",
    "claude-code"
  ],
  "license": "MIT"
}
