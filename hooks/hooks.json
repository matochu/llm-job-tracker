{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/llm-hooks/pre-tool-guard.js"
            ],
            "timeout": 30,
            "statusMessage": "Checking job-search guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/llm-hooks/post-tool-check.js"
            ],
            "timeout": 30,
            "statusMessage": "Checking job-search edits"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PLUGIN_ROOT}/scripts/llm-hooks/stop-check.js"
            ],
            "timeout": 30
          }
        ]
      }
    ]
  }
}
