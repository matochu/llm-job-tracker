{
  "permissions": {
    "allow": [
      "mcp__playwright__browser_snapshot",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_take_screenshot",
      "mcp__chrome-devtools__take_snapshot",
      "mcp__chrome-devtools__navigate_page",
      "WebSearch",
      "Bash(curl *)",
      "Bash(python3 *)",
      "Bash(rg *)",
      "Bash(sed *)",
      "Bash(grep *)",
      "Bash(awk *)",
      "Bash(sort *)",
      "Bash(uniq *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(ls *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PROJECT_DIR}/scripts/llm-hooks/pre-tool-guard.js"
            ],
            "timeout": 30,
            "statusMessage": "Checking job-search guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PROJECT_DIR}/scripts/llm-hooks/post-tool-check.js"
            ],
            "timeout": 30,
            "statusMessage": "Checking job-search edits"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node",
            "args": [
              "${CLAUDE_PROJECT_DIR}/scripts/llm-hooks/stop-check.js"
            ],
            "timeout": 30
          }
        ]
      }
    ]
  }
}
