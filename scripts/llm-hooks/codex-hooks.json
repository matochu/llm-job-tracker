{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|functions.exec_command|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/llm-hooks/pre-tool-guard.js\"",
            "timeout": 30,
            "statusMessage": "Checking job-search guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/llm-hooks/post-tool-check.js\"",
            "timeout": 30,
            "statusMessage": "Checking job-search edits"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/llm-hooks/stop-check.js\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
