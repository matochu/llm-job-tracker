{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|functions.exec_command|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/llm-hooks/pre_tool_guard.py\"",
            "timeout": 30,
            "statusMessage": "Checking job-search guardrails"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/llm-hooks/post_tool_check.py\"",
            "timeout": 30,
            "statusMessage": "Checking job-search edits"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$(git rev-parse --show-toplevel)/scripts/llm-hooks/stop_check.py\"",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

